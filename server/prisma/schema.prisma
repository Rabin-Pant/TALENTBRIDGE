// TalentBridge — Prisma Schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  SEEKER
  EMPLOYER
  ADMIN
}

enum ExperienceLevel {
  ENTRY
  JUNIOR
  MID
  SENIOR
  LEAD
  EXECUTIVE
}

enum CompanySize {
  STARTUP // 1–10
  SMALL // 11–50
  MEDIUM // 51–200
  LARGE // 201–1000
  ENTERPRISE // 1000+
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
  REMOTE
}

enum JobStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  ACCEPTED
  REJECTED
}

enum NotificationType {
  APPLICATION
  STATUS_UPDATE
  JOB_MATCH
  SYSTEM
  LIKE
  COMMENT
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id                     String            @id @default(uuid())
  email                  String            @unique
  password               String
  fullName               String
  role                   Role              @default(SEEKER)
  active                 Boolean           @default(true)
  approved               Boolean           @default(false)
  createdAt              DateTime          @default(now())
  lastLogin              DateTime?
  profilePicture         String?
  coverPicture           String?
  failedPasswordAttempts Int               @default(0)
  lockoutUntil           DateTime?
  reactions              MessageReaction[]

  // Seeker-only fields
  currentTitle    String?
  bio             String?
  location        String?
  phone           String?
  experienceLevel ExperienceLevel?
  skills          String[]         @default([])
  resumeFileName  String?
  education       Json?
  workExperience  Json?

  // Employer-only fields
  companyName        String?
  companyWebsite     String?
  companySize        CompanySize?
  industry           String?
  companyDescription String?
  companyAddress     String?
  companyPhone       String?
  companyRegNumber   String?
  companyDocument    String?

  // Relations
  postedJobs    Job[]          @relation("EmployerJobs")
  applications  Application[]  @relation("SeekerApplications")
  notifications Notification[] @relation("UserNotifications")

  // Social relations
  posts                Post[]         @relation("UserPosts")
  likes                Like[]         @relation("UserLikes")
  comments             Comment[]      @relation("UserComments")
  sentConnections      Connection[]   @relation("SentConnections")
  receivedConnections  Connection[]   @relation("ReceivedConnections")
  conversationsAsUser1 Conversation[] @relation("ConversationUser1")
  conversationsAsUser2 Conversation[] @relation("ConversationUser2")
  sentMessages         Message[]      @relation("SentMessages")

  @@map("users")
}

// ─────────────────────────────────────────
// JOB
// ─────────────────────────────────────────

model Job {
  id              String          @id @default(uuid())
  title           String
  description     String
  company         String
  location        String
  jobType         JobType
  experienceLevel ExperienceLevel
  industry        String
  salaryMin       Int?
  salaryMax       Int?
  requirements    String[]        @default([])
  benefits        String[]        @default([])
  skills          String[]        @default([])
  status          JobStatus       @default(ACTIVE)
  postedAt        DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  employerId   String
  employer     User          @relation("EmployerJobs", fields: [employerId], references: [id], onDelete: Cascade)
  applications Application[]

  @@map("jobs")
}

// ─────────────────────────────────────────
// APPLICATION
// ─────────────────────────────────────────

model Application {
  id             String            @id @default(uuid())
  status         ApplicationStatus @default(PENDING)
  coverLetter    String?
  resumeSnapshot String? // copy of resume filename at time of apply
  employerNote   String?
  appliedAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  // Relations
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  applicantId String
  applicant   User   @relation("SeekerApplications", fields: [applicantId], references: [id], onDelete: Cascade)

  // Prevent duplicate applications
  @@unique([jobId, applicantId])
  @@map("applications")
}

// ─────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  title     String
  message   String
  type      NotificationType
  link      String? // e.g. /seeker/applications/123
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  // Relations
  recipientId String
  recipient   User   @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum PostType {
  UPDATE
  ACHIEVEMENT
  JOB_UPDATE
  ANNOUNCEMENT
}

model Post {
  id         String   @id @default(uuid())
  content    String
  image      String?
  type       PostType @default(UPDATE)
  likesCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  authorId String
  author   User      @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)
  likes    Like[]
  comments Comment[]

  @@map("posts")
}

model Like {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("UserLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("likes")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  postId   String
  post     Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String
  author   User      @relation("UserComments", fields: [authorId], references: [id], onDelete: Cascade)
  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  @@map("comments")
}

model Connection {
  id        String           @id @default(uuid())
  status    ConnectionStatus @default(PENDING)
  createdAt DateTime         @default(now())

  senderId   String
  sender     User   @relation("SentConnections", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User   @relation("ReceivedConnections", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@map("connections")
}

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user1Id  String
  user1    User      @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id  String
  user2    User      @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]

  deletedFor String[] @default([]) // Users who soft-deleted this conversation

  @@unique([user1Id, user2Id])
  @@map("conversations")
}

model Message {
  id        String   @id @default(uuid())
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  deletedFor String[]          @default([])
  reactions  MessageReaction[]

  @@map("messages")
}

model MessageReaction {
  id        String   @id @default(uuid())
  type      String
  userId    String
  messageId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}
